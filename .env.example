# Copy to `.env` (or `.env.local`) and fill in real values.
#
# NOTE: Variables prefixed with `VITE_` are exposed to client-side code.
# Keep secrets in server-only variables (no `VITE_` prefix).

# --- Comcash (server-only) ---
CC_OPEN_API_KEY=
CC_PIN=
CC_PASSWORD=

# --- Decap CMS (Netlify CMS) ---
# No app env vars required. Configuration lives in `static/admin/config.yml`.
