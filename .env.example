# Copy to `.env` (or `.env.local`) and fill in real values.
#
# NOTE: In Vite/SvelteKit, variables prefixed with `VITE_` are exposed to client-side code.
# This repo currently uses `VITE_CC_*` in server routes, but you should treat these as secrets
# and migrate to server-only env vars when you refactor the Comcash integration.

# --- Comcash (current code expects these exact names) ---
VITE_CC_OPEN_API_KEY=your_comcash_open_api_key
VITE_CC_PIN=your_comcash_pin
VITE_CC_PASSWORD=your_comcash_password

# --- Contentful (legacy; kept for reference) ---
VITE_CONTENTFUL_SPACE_ID=
VITE_CONTENTFUL_DELIVERY_API_TOKEN=

# --- Decap CMS (Netlify CMS) ---
# No app env vars required. Configuration lives in `static/admin/config.yml`.
